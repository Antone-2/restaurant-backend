# Environment Variables for The Quill Restaurant Backend
# Copy this to .env and fill in your values
# Add these in Render Dashboard > Your Backend > Environment Variables

# ============================================
# REQUIRED
# ============================================

# MongoDB Connection String (from MongoDB Atlas or other provider)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/thequill?retryWrites=true&w=majority

# JWT Secret for token signing (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# ============================================
# REQUIRED: CORS & URLs
# ============================================

# Frontend URL (Vercel deployment)
FRONTEND_URL=https://restaurant-frontend-ochre-rho.vercel.app

# Allowed Origins (comma-separated, for CORS)
ALLOWED_ORIGINS=https://restaurant-frontend-ochre-rho.vercel.app,http://localhost:5173,http://localhost:8080

# ============================================
# REQUIRED: Admin Configuration
# ============================================

# Admin email addresses (comma-separated)
ADMIN_EMAILS=admin@thequill.com,thequillrestaurant@gmail.com,pomraningrichard@gmail.com

# Optional: Single admin email for notifications
ADMIN_EMAIL=thequillrestaurant@gmail.com

# ============================================
# OPTIONAL: M-Pesa Payment (Kenya MPesa Integration)
# ============================================

# Get these from Safaricom Developer Portal
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENVIRONMENT=sandbox  # Use 'production' for live

# Callback URL (should point to your Render backend)
MPESA_CALLBACK_URL=https://your-backend.onrender.com/api/payments/mpesa/callback

# ============================================
# OPTIONAL: Email (Brevo/Sendinblue)
# ============================================

# Get from Brevo dashboard
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@thequill.com
BREVO_SENDER_NAME=The Quill Restaurant

# ============================================
# OPTIONAL: Restaurant Location (for delivery calculations)
# ============================================

# Restaurant coordinates (Nambale, Busia)
RESTAURANT_LAT=0.0618
RESTAURANT_LNG=34.1069

# ============================================
# OPTIONAL: Data Retention (GDPR)
# ============================================

# Days to retain anonymized data after account deletion
DATA_RETENTION_DAYS=90

# ============================================
# PORT (Don't change - Render sets this)
# ============================================

PORT=3001
NODE_ENV=production
